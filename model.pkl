import numpy as np

# 1. Replace '?' with NaN (Not a Number)
df['horsepower'] = df['horsepower'].replace('?', np.nan)

# 2. Convert horsepower column data type from text to float (number)
df['horsepower'] = df['horsepower'].astype(float)

# 3. Fill the missing values with the median of the horsepower column
df['horsepower'] = df['horsepower'].fillna(df['horsepower'].median())

# 4. Check the updated data structure
df.info()

# View statistical details of the clean dataset
df.describe()

# Get descriptive statistics
print(df.describe())

# Check for missing values
print("\nMissing values:")
print(df.isnull().sum())

# Average mpg by cylinder count
avg_mpg_by_cyl = df.groupby('cylinders')['mpg'].mean().reset_index()
print(avg_mpg_by_cyl)

