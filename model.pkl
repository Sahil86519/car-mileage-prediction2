import subprocess
from pyngrok import ngrok

# Step 1: Kill any previous stuck connections
ngrok.kill()

# Step 2: Run Streamlit safely in the background using subprocess (No freezing)
print("Starting Streamlit app...")
subprocess.Popen(["streamlit", "run", "app.py", "--server.port", "8501"])

# Step 3: Connect ngrok tunnel immediately
print("Generating your secure link...")
public_url = ngrok.connect(8501)

print("\nYOUR ERROR-FREE APP LINK IS READY 👇")
print(public_url)
